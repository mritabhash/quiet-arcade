# Copy to .env.local and fill in from Supabase → Settings → API.
# Anon (public) key ONLY — never the service_role key.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Optional: PostHog product analytics. Leave blank to keep analytics off.
# Project API key (starts with phc_) from PostHog → Project Settings.
# Host is https://us.i.posthog.com (US) or https://eu.i.posthog.com (EU).
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Optional: Mapillary street-level imagery for Map Drop → Moderate (GeoGuessr).
# Free client token from https://www.mapillary.com/dashboard/developers
# (register an app → Client Token). Leave blank to disable Moderate street view.
VITE_MAPILLARY_TOKEN=
